# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Claude API key — get one at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Which model to use for the orchestrator
CLAUDE_MODEL=claude-sonnet-4-6

# Strategy target
TICKER=AAPL
INTERVAL=5m
TIME_FRAME=60d

# Optimization settings
OPT_GENERATIONS=200
OPT_POPSIZE=50
OPT_MIN_TRADES=10
OPT_PATIENCE=20

# Deployment gate thresholds
GATE_MIN_SHARPE=0.5
GATE_MAX_OVERFIT_GAP=1.5
GATE_MIN_TRADES=10
GATE_MAX_DRAWDOWN=0.15

# Orchestrator loop settings
CHECK_INTERVAL_MIN=30      # minutes between health checks during market hours
DEGRADATION_SHARPE=0.3     # re-optimize when live Sharpe drops below this
